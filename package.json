{
  "name": "@mambalabsdev/mcp-company-social-presence-mapper",
  "version": "1.0.0",
  "description": "MCP server for the Mamba Labs Company Social Presence Mapper actor on Apify. Map a company domain to its official LinkedIn, X, Instagram, Facebook, and YouTube URLs plus follower counts, returned as flat Clay-ready JSON.",
  "type": "module",
  "bin": {
    "mcp-company-social-presence-mapper": "./build/index.js"
  },
  "scripts": {
    "build": "tsc && chmod +x build/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "social-media",
    "social-presence",
    "follower-counts",
    "company-data",
    "domain-enrichment",
    "apify",
    "clay"
  ],
  "author": "Mamba Labs <labs@mambamindsetgrowth.com>",
  "license": "MIT",
  "homepage": "https://apify.com/mambalabs",
  "repository": {
    "type": "git",
    "url": "https://github.com/mambalabsdev/mcp-company-social-presence-mapper"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^6.0.3"
  },
  "mcpName": "com.mambabuilt/mcp-company-social-presence-mapper"
}
