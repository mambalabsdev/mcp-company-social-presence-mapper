{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "com.mambabuilt/mcp-company-social-presence-mapper",
  "description": "Map a company domain to its social media URLs and follower counts via Apify.",
  "version": "1.0.0",
  "repository": {
    "url": "https://github.com/mambalabsdev/mcp-company-social-presence-mapper",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@mambalabsdev/mcp-company-social-presence-mapper",
      "version": "1.0.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "APIFY_TOKEN",
          "description": "Apify API token from https://console.apify.com/account/integrations",
          "isRequired": true,
          "isSecret": true,
          "format": "string"
        }
      ]
    }
  ]
}
